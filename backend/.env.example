# 复制为 .env 后按需修改。留空则使用可运行的 Mock 后端。

# ── 应用 ──────────────────────────────────────────────
APP_ENV=dev
APP_TIMEZONE_OFFSET_HOURS=8          # 中国无夏令时，固定 UTC+8

# ── 合规：高考熔断窗口（含首尾，Asia/Shanghai）──────────────
GAOKAO_BLACKOUT_START=2026-06-07
GAOKAO_BLACKOUT_END=2026-06-10
# 防沉迷
DAILY_USAGE_LIMIT_MINUTES=180        # 单日 ≤3 小时
NIGHT_LOCK_START_HOUR=23             # 23:00 起锁定
NIGHT_LOCK_END_HOUR=6                # 06:00 解锁

# ── 后端选择 ──────────────────────────────────────────
PARSER_BACKEND=mock                  # （OCR 见下方 OCR_ENDPOINT）
LLM_BACKEND=mock                     # mock | real（OpenAI 兼容端点 DeepSeek/Qwen via vLLM）

# ── 真实向量检索（bge + Milvus）────────────────────────────
EMBEDDER_BACKEND=mock                # mock | bge_http | bge_local
EMBED_BASE_URL=http://127.0.0.1:8001/v1   # OpenAI/TEI 兼容 /embeddings
EMBED_MODEL=bge-large-zh-v1.5
EMBED_DIM=256                        # mock=256；bge-large-zh/bge-m3=1024
VECTOR_STORE=memory                  # memory(内存真实余弦) | milvus
MILVUS_URI=http://127.0.0.1:19530
MILVUS_COLLECTION=zkt_chunks
RERANKER_BACKEND=mock                # mock | bge_http
RERANK_BASE_URL=http://127.0.0.1:8001     # POST /rerank（bge-reranker-large, TEI 兼容）

# ── 真实 LLM（LLM_BACKEND=real 时生效，vLLM/OpenAI 兼容：DeepSeek/Qwen）────
LLM_BASE_URL=http://127.0.0.1:8001/v1
LLM_API_KEY=EMPTY
LLM_MODEL=Qwen2-7B-Instruct
LLM_TIMEOUT_S=30
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0.2
LLM_JSON_MODE=true
LLM_CACHE_SIZE=256
LLM_HEALTH_CHECK=true          # 启动探活失败自动降级到 Mock

# ── 真实 OCR/公式 ────────────────────────────────────────
# 统一 HTTP 网关（推荐）：网关后端对接百度 PP-FormulaNet / 阿里云 RecognizeEduPaperStructed
OCR_ENDPOINT=                  # 例：http://127.0.0.1:8001/ocr/recognize（留空用 Mock）
OCR_TIMEOUT_S=20
OCR_MAX_RETRIES=2
BAIDU_FORMULA_ENDPOINT=
BAIDU_API_KEY=
BAIDU_SECRET_KEY=
ALIYUN_EDU_ACCESS_KEY=
ALIYUN_EDU_SECRET=

# 本地真机联调：python scripts/fake_llm_server.py 起契约一致的假服务，
# 再设 LLM_BACKEND=real、LLM_BASE_URL=http://127.0.0.1:8001/v1、OCR_ENDPOINT=http://127.0.0.1:8001/ocr/recognize
